# Nginx reverse proxy: public HTTPS -> local dashboard (port 3000).
# Put in /etc/nginx/sites-available/deal-dashboard, symlink to sites-enabled,
# then run certbot (see DEPLOY.md) to add the SSL certificate automatically.

server {
    listen 80;
    server_name dashboard.tvoje-domena.cz;   # <-- your domain or subdomain

    location / {
        proxy_pass http://127.0.0.1:3000;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 120s;   # first dashboard load verifies liveness
    }
}
