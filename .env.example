# Copy to .env on the server and fill in real values. NEVER commit the real .env.

# --- Supabase (database) ---
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_KEY=YOUR-ANON-KEY

# --- CRM webhook (n8n -> GoHighLevel) ---
N8N_WEBHOOK_URL=https://your-n8n/webhook/xxxx

# --- AI (valuation / vision, optional for the v2 cycle) ---
OPENAI_API_KEY=sk-...

# --- Proxy (only if running the Playwright scrapers) ---
APIFY_PROXY_PASSWORD=

# --- Dashboard / Auth (production) ---
DASHBOARD_PORT=3000
# subdomain pointed at this VPS (A record). Traefik issues HTTPS for it.
DASHBOARD_DOMAIN=flip.tvojedomena.cz
AUTH_ENABLED=1
# long random string, e.g. output of:  openssl rand -base64 32
SESSION_SECRET=CHANGE-ME-RANDOM
# set to 1 once the site is served over HTTPS
COOKIE_SECURE=1
# clients self-register with this code (give it only to people who should have access)
INVITE_CODE=CHANGE-ME-INVITE
